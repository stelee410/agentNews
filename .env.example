# agentNews environment configuration. Copy to .env and adjust.

# --- Server ---
HOST=0.0.0.0
PORT=3000

# Public base URL (used to build absolute links in OpenAPI / llms.txt).
# Leave empty to derive from the incoming request.
AGENTNEWS_BASE_URL=https://news.example.com

# --- Storage ---
# Runtime data dir; holds content/ (markdown source of truth) and index.db.
AGENTNEWS_DATA_DIR=./data

# --- Bootstrap admin key (SPEC §8) ---
# On first boot, if no admin key exists, one is created from this value.
# Use a long random string formatted like an_admin_<random>, e.g.:
#   an_admin_$(openssl rand -base64 24 | tr -d /+=)
# IMPORTANT: remove this var after the first successful boot.
AGENTNEWS_BOOTSTRAP_ADMIN=

# --- Limits & cache (optional; sensible defaults shown) ---
AGENTNEWS_MAX_BODY_BYTES=262144
AGENTNEWS_READ_RATE=120
AGENTNEWS_WRITE_RATE=30
AGENTNEWS_CACHE_MAX_AGE=60
AGENTNEWS_CACHE_SWR=600
AGENTNEWS_LLMS_FULL_LIMIT=50
