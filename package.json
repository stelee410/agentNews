{
  "name": "agentnews",
  "version": "0.1.0",
  "description": "Agent-maintained, agent-served bilingual news & deep-content aggregation platform",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "reindex": "tsx scripts/reindex.ts",
    "reindex:prod": "node dist/scripts/reindex.js",
    "bootstrap": "tsx scripts/bootstrap-admin.ts",
    "bootstrap:prod": "node dist/scripts/bootstrap-admin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.8.1",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.14",
    "markdown-it": "^14.1.0",
    "nanoid": "^5.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
